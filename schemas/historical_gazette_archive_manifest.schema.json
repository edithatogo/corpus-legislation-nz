{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edithatogo/corpus-legislation-nz/schemas/historical_gazette_archive_manifest.schema.json",
  "title": "Historical Gazette archive manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "source_name",
    "source_tier",
    "source_year",
    "source_index_url",
    "generated_at_utc",
    "record_count",
    "record_kind_counts",
    "historical_year_counts",
    "index_page_count",
    "issue_row_count",
    "rights_warning",
    "access_warning",
    "coverage_warning",
    "records",
    "content_sha256",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_id": {
      "const": "victoria_lexisnexis_gazette"
    },
    "source_name": {
      "type": "string",
      "minLength": 1
    },
    "source_tier": {
      "const": "historical"
    },
    "source_year": {
      "type": "string",
      "pattern": "^\\d{4}$"
    },
    "source_index_url": {
      "type": "string",
      "format": "uri"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "record_count": {
      "type": "integer",
      "minimum": 0
    },
    "record_kind_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "historical_year_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "index_page_count": {
      "type": "integer",
      "minimum": 0
    },
    "issue_row_count": {
      "type": "integer",
      "minimum": 0
    },
    "rights_warning": {
      "type": "string",
      "minLength": 1
    },
    "access_warning": {
      "type": "string",
      "minLength": 1
    },
    "coverage_warning": {
      "type": "string",
      "minLength": 1
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "content_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "manifest_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "$defs": {
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stable_id",
        "source_id",
        "source_name",
        "source_tier",
        "record_kind",
        "source_url",
        "retrieval_method",
        "retrieved_at",
        "content_sha256",
        "raw_artifact_path",
        "rights_note",
        "source_local_id",
        "coverage_state"
      ],
      "properties": {
        "stable_id": {
          "type": "string",
          "pattern": "^gazette-victoria-lexisnexis-\\d{4}(-index|-\\d{3})$"
        },
        "source_id": {
          "const": "victoria_lexisnexis_gazette"
        },
        "source_name": {
          "type": "string",
          "minLength": 1
        },
        "source_tier": {
          "const": "historical"
        },
        "record_kind": {
          "type": "string",
          "enum": ["historical_index", "historical_page", "historical_pdf"]
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "retrieval_method": {
          "type": "string",
          "minLength": 1
        },
        "retrieved_at": {
          "type": "string",
          "format": "date-time"
        },
        "content_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "raw_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "rights_note": {
          "type": "string",
          "minLength": 1
        },
        "source_local_id": {
          "type": "string",
          "pattern": "^\\d{4}(-index|-\\d{3})$"
        },
        "coverage_state": {
          "type": "string",
          "enum": ["complete", "partial", "gap", "blocked", "unknown"]
        },
        "http_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "extraction": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "historical_year": {
              "type": "string",
              "pattern": "^\\d{4}$"
            },
            "issue_number": {
              "type": "string",
              "pattern": "^\\d{3}$"
            },
            "issue_label": {
              "type": "string",
              "minLength": 1
            },
            "page_start": {
              "type": "integer",
              "minimum": 0
            },
            "page_end": {
              "type": "integer",
              "minimum": 0
            },
            "row_text": {
              "type": "string",
              "minLength": 1
            },
            "year_links": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              }
            },
            "year_link_count": {
              "type": "integer",
              "minimum": 0
            },
            "issue_row_count": {
              "type": "integer",
              "minimum": 0
            },
            "retrieval_method": {
              "type": "string",
              "minLength": 1
            },
            "access_note": {
              "type": "string",
              "minLength": 1
            },
            "source_index_url": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "provenance": {
          "type": "object",
          "additionalProperties": true
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
